{
  "name": "node-sf-bulk2",
  "version": "0.2.0",
  "description": "Node.js implementation of Salesforce Bulk API 2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "start:dev": "nodemon",
    "build": "rimraf ./dist && tsc",
    "test": "vitest run",
    "test:unit": "vitest run src/__tests__/bulk2.unit.test.ts",
    "test:integration": "vitest run src/__tests__/bulk2.integration.test.ts",
    "test:watch": "vitest",
    "eslint": "eslint src/**",
    "prepublishOnly": "npm run build && npm run test:unit"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "nodemon": "^3.1.0",
    "rimraf": "^6.0.0",
    "ts-node": "^10.9.0",
    "typedoc": "^0.28.0",
    "typescript": "~5.8.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "axios": "^1.16.0"
  }
}
